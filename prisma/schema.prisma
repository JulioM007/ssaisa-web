// Prisma Schema — SSAISA Inmobiliaria

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum PropertyType {
  CASA
  DEPARTAMENTO
  TERRENO
  LOCAL_COMERCIAL
  OFICINA
  BODEGA
  DESARROLLO
}

enum OperationType {
  VENTA
  RENTA
  PREVENTA
}

enum PropertyStatus {
  ACTIVA
  INACTIVA
  VENDIDA
  RENTADA
  RESERVADA
}

enum UserRole {
  ADMIN
  EDITOR
}

enum InterestType {
  COMPRAR
  RENTAR
  INVERTIR
  VENDER
  ASESOR_EXTERNO
  OTRO
}

enum PreferredChannel {
  WHATSAPP
  LLAMADA
  EMAIL
}

// ─── Modelos ──────────────────────────────────────────────────────────────────

model Category {
  id         String     @id @default(cuid())
  name       String     @unique
  slug       String     @unique
  icon       String?
  properties Property[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@map("categories")
}

model Property {
  id              String         @id @default(cuid())
  title           String
  slug            String         @unique
  description     String
  price           Decimal        @db.Decimal(12, 2)
  priceNote       String?
  type            PropertyType
  operation       OperationType
  status          PropertyStatus @default(ACTIVA)
  featured        Boolean        @default(false)

  // Ubicación
  address         String?
  municipality    String
  state           String         @default("Nuevo León")
  zipCode         String?
  latitude        Float?
  longitude       Float?
  mapEmbed        String?

  // Características físicas
  terrainM2       Float?
  buildingM2      Float?
  bedrooms        Int?
  bathrooms       Float?
  parkings        Int?
  floors          Int?
  antiquity       Int?
  constructionYear Int?

  // Amenidades
  amenities       String[]

  // SEO
  metaTitle       String?
  metaDescription String?

  // Relaciones
  images          PropertyImage[]
  categories      Category[]
  development     Development?   @relation(fields: [developmentId], references: [id])
  developmentId   String?

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([municipality])
  @@index([type])
  @@index([operation])
  @@index([status])
  @@index([featured])
  @@index([price])
  @@map("properties")
}

model PropertyImage {
  id         String   @id @default(cuid())
  url        String
  alt        String?
  order      Int      @default(0)
  isPrimary  Boolean  @default(false)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  propertyId String
  createdAt  DateTime @default(now())

  @@index([propertyId])
  @@map("property_images")
}

model Development {
  id              String     @id @default(cuid())
  name            String
  slug            String     @unique
  description     String
  developer       String
  developerLogo   String?
  location        String
  municipality    String
  masterplanImage String?
  phases          String?
  priceFrom       Decimal?   @db.Decimal(12, 2)
  status          String     @default("EN_VENTA")
  website         String?
  featured        Boolean    @default(false)
  gallery         String[]

  metaTitle       String?
  metaDescription String?

  properties      Property[]
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([municipality])
  @@index([featured])
  @@map("developments")
}

model BlogPost {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String
  content     String
  coverImage  String?
  author      String    @default("Equipo SSAISA")
  authorImage String?
  tags        String[]
  published   Boolean   @default(false)
  publishedAt DateTime?

  metaTitle       String?
  metaDescription String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([published])
  @@index([publishedAt])
  @@map("blog_posts")
}

model Contact {
  id               String           @id @default(cuid())
  name             String
  email            String
  phone            String?
  interestType     InterestType
  preferredChannel PreferredChannel @default(WHATSAPP)
  message          String?
  propertySlug     String?
  read             Boolean          @default(false)
  notes            String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([read])
  @@index([createdAt])
  @@map("contacts")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      UserRole @default(EDITOR)
  avatar    String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}
